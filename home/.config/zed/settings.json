{
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha"
  },
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha"
  },
  "buffer_font_family": "CommitMono Nerd Font Mono",
  "buffer_font_features": {
    "ss01": true,
    "ss02": true,
    "ss03": true,
    "ss04": true,
    "ss05": true,
    "cv02": true,
    "cv06": true,
    "cv10": true
  },
  "buffer_font_size": 12,
  "ui_font_family": ".SystemUIFont",
  "ui_font_size": 14,
  "vim_mode": true,
  "colorize_brackets": true,
  "completion_menu_scrollbar": "auto",
  "auto_signature_help": true,
  "wrap_guides": [80],
  "use_system_window_tabs": true,
  "minimap": {
    "show": "auto"
  },
  "indent_guides": {
    "coloring": "indent_aware"
  },
  "vertical_scroll_margin": 0,
  "horizontal_scroll_margin": 0,
  "sticky_scroll": {
    "enabled": true
  },
  "use_smartcase_search": true,
  "inlay_hints": {
    "enabled": true
  },
  "project_panel": {
    "git_status_indicator": true
  },
  "git_panel": {
    "file_icons": true
  },
  "semantic_tokens": "combined",
  "document_folding_ranges": "on",
  "document_symbols": "on",
  "autosave": "on_focus_change",
  "tabs": {
    "close_position": "left",
    "file_icons": true
  },
  "soft_wrap": "editor_width",
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "diagnostics": {
    "inline": {
      "enabled": true
    }
  },
  "git": {
    "inline_blame": {
      "show_commit_summary": true
    },
    "hunk_style": "unstaged_hollow"
  },
  "terminal": {
    "option_as_meta": true,
    "line_height": "comfortable",
    "detect_venv": {
      "on": {
        "activate_script": "fish"
      }
    }
  },
  "auto_install_extensions": {
    "biome": true,
    "catppuccin": true,
    "catppuccin-icons": true,
    "codebook": true,
    "fish": true,
    "ghostty": true,
    "git-firefly": true,
    "make": true,
    "neocmake": true,
    "nix": true,
    "rumdl": true,
    "swift": true,
    "toml": true,
    "tombi": true,
    "wakatime": true,
    "xml": true
  },
  "languages": {
    "C++": {
      "tab_size": 2
    },
    "Fish": {
      "formatter": {
        "external": {
          "command": "fish_indent"
        }
      }
    },
    "JSON": {
      "formatter": {
        "language_server": { "name": "biome" }
      }
    },
    "JSONC": {
      "formatter": {
        "language_server": { "name": "biome" }
      }
    },
    "Markdown": {
      "format_on_save": "on",
      "formatter": {
        "language_server": { "name": "rumdl" }
      },
      "language_servers": ["rumdl"]
    },
    "Nix": {
      "language_servers": ["nixd", "!nil"]
    },
    "Python": {
      "language_servers": [
        "ty",
        "ruff",
        "!basedpyright",
        "!pyrefly",
        "!pyright",
        "!pylsp",
        "..."
      ]
    },
    "Shell Script": {
      "tab_size": 2,
      "formatter": {
        "external": {
          "command": "shfmt",
          "arguments": ["--filename", "{buffer_path}", "--indent", "2"]
        }
      }
    }
  },
  "vim": {
    "toggle_relative_line_numbers": true,
    "use_smartcase_find": true
  },
  "which_key": {
    "enabled": true
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  }
}
