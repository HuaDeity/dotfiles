font-family = "CommitMono Nerd Font Mono"
font-feature = ss01, ss02, ss03, ss04, ss05, cv02, cv06, cv10 

adjust-cell-height = 20%
adjust-cursor-height = 20%

theme = dark:Catppuccin Mocha,light:Catppuccin Latte

mouse-hide-while-typing = true

window-height = 42
window-width = 140

clipboard-read = allow

shell-integration-features = sudo, ssh-env, ssh-terminfo

macos-option-as-alt = true

auto-update-channel = tip

# keybind = global:ctrl+grave_accent=toggle_quick_terminal
keybind = performable:super+c=copy_to_clipboard
# keybind = performable:super+alt+n=csi:110;11u
keybind = super+bracket_left=unbind
keybind = super+bracket_right=unbind
keybind = ctrl+grave_accent=goto_split:next

keybind = shift+enter=text:\n
