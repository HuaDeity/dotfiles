# vim: set ft=toml:

{{- if ne .chezmoi.os "windows" }}
[".config/glamour/themes"]
    type = "archive"
    url = "https://github.com/catppuccin/glamour/archive/main.tar.gz"
    exact = true
    stripComponents = 2
    refreshPeriod = "168h"
    include = ["*/themes/*.json"]
{{- if lookPath "delta" }}
[".config/delta/themes"]
    type = "archive"
    url = "https://github.com/catppuccin/delta/archive/main.tar.gz"
    exact = true
    stripComponents = 1
    refreshPeriod = "168h"
    include = ["*/*.gitconfig"]
{{- end }}
{{- if lookPath "fzf" }}
[".config/fzf/themes"]
    type = "archive"
    url = "https://github.com/catppuccin/fzf/archive/main.tar.gz"
    exact = true
    stripComponents = 2
    refreshPeriod = "168h"
    include = ["*/themes/*.fish"]
{{- end }}
{{- if lookPath "lazygit" }}
[".config/lazygit/themes"]
    type = "archive"
    url = "https://github.com/catppuccin/lazygit/archive/main.tar.gz"
    exact = true
    stripComponents = 2
    refreshPeriod = "168h"
    include = ["*/themes-mergable/**"]
{{- end }}
{{- if lookPath "tmux" }}
[".local/share/tmux/plugins/tmux-catppuccin"]
    type = "archive"
    url = "https://github.com/catppuccin/tmux/archive/main.tar.gz"
    exact = true
    stripComponents = 1
    refreshPeriod = "168h"
{{- end }}
{{- end }}
